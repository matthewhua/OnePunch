# ========== 操作系统与通用临时文件 ==========
.DS_Store       # Mac 系统文件
Thumbs.db       # Windows 系统文件
*~              # 类Unix系统临时文件
*.swp           # Vim 临时文件
*.swo           # Vim 交换文件
*.bak           # 备份文件
*.tmp           # 临时文件

# ========== IDE 配置文件 ==========
.idea/*         # IntelliJ IDEA 配置目录
!.idea/runConfigurations/  # 保留运行配置（可选）
*.iml           # IntelliJ IDEA 项目文件
*.iws           # IntelliJ IDEA 工作区文件
.vscode/        # VS Code 配置目录
*.vscode        # VS Code 单文件配置
.gradle/        # Gradle 缓存目录（IDE 可能关联）
*.project       # Eclipse 项目文件
*.classpath     # Eclipse 类路径文件
.settings/      # Eclipse 配置目录
.fleet/         # Fleet IDE 配置
.metals/        # Scala Metals 配置
.bloop/         # Bloop 编译服务器

# ========== 编译产物 & 缓存文件 ==========
target/         # Rust/Scala 编译输出目录
classes/        # Java 编译输出目录
*.class         # Java/Scala 编译生成的类文件
*.cache         # 各类缓存文件
*.log           # 日志文件（通用）
logs/           # 日志目录（通用）
out/            # 部分IDE的输出目录

# ========== Java 特定 ==========
*.jar
*.war
*.ear
*.javap
*.jmap
*.jstack
*.snap          # Java 快照文件

# ========== Scala 特定 ==========
*.scala.html
*.sbt
.ivy2/          # Ivy 依赖缓存
*.ivy
project/target/ # Scala sbt 项目的编译目录
build.sbt.lock  # sbt 锁文件

# ========== Rust 特定 ==========
*.rs.bk         # Rust 备份文件
**/target/      # Rust 编译输出目录（所有子目录）
Cargo.lock      # Rust 依赖锁文件（库项目应忽略，二进制项目应提交）
*.rlib          # Rust 静态库
*.dll           # Rust 动态库（Windows）
*.so            # Rust 动态库（Linux）
*.dylib         # Rust 动态库（Mac）
**/*.rs.bk      # Rust 备份文件（所有子目录）
.rustc_info.json  # Rust 编译器信息
CACHEDIR.TAG    # Rust target 缓存标记

# ========== Gradle 特定 ==========
build/          # Gradle 构建输出目录（全局及模块内）
!gradle/wrapper/gradle-wrapper.jar  # 保留 Gradle Wrapper 核心文件（建议提交）
!**/src/main/**/build/  # 避免误删源码目录内的 build（若有特殊需求）
!**/src/test/**/build/
gradle.properties  # 全局 Gradle 配置（若含敏感信息可忽略，否则建议提交）
local.properties   # 本地配置（如Android SDK路径，含本地信息需忽略）
*.gradle          # Gradle 任务缓存文件（非脚本）

# ========== Node.js 特定 ==========
node_modules/    # 依赖包目录，禁止提交
npm-debug.log*   # npm 调试日志
yarn-debug.log*  # Yarn 调试日志
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
# 注意：不要使用 *.lock 这样的通配符，会误删重要的锁文件
dist/            # 构建输出目录（如前端打包文件）
coverage/        # 测试覆盖率报告
*.tsbuildinfo    # TypeScript 构建信息
*.js.map         # JavaScript 源码映射文件
*.d.ts           # 自动生成的类型定义文件（手动维护的可保留）
*.cmd            # Node.js 命令行脚本（如 cross-env、nodemon 的 cmd 文件）
*.ps1            # Node.js PowerShell 脚本
*.bat            # Node.js Batch 脚本（若有）

# ========== Maven 特定 ==========
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ========== Python 特定 ==========
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
*.egg-info/
dist/
build/
*.egg

# ========== Go 特定 ==========
*.exe
*.exe~
*.test
*.out
go.work
vendor/

# ========== C/C++ 特定 ==========
*.o
*.a
*.out
*.obj
*.elf
*.gch
*.pch
*.dSYM/
*.su
*.idb
*.pdb
*.ilk
*.exp
*.lib

# ========== 其他常见文件 ==========
*.pid
*.seed
*.pid.lock
.env
.env.local
.env.*.local
*.orig
*.rej
.cache/