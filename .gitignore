# ========== 操作系统与通用临时文件 ==========
# Mac 系统文件
.DS_Store
# Windows 系统文件
Thumbs.db
# 类Unix系统临时文件
*~
# Vim 临时文件
*.swp
*.swo
# 备份与临时文件
*.bak
*.tmp

# ========== IDE 配置文件 ==========
# IntelliJ IDEA 配置目录 (所有层级)
**/.idea/
# 保留运行配置（可选）
!.idea/runConfigurations/
# IntelliJ IDEA 项目文件
*.iml
*.iws
# VS Code 配置目录
**/.vscode/
# VS Code 单文件配置
*.vscode
# Gradle 缓存目录（IDE 可能关联）
.gradle/
# Eclipse 项目文件
*.project
*.classpath
# Eclipse 配置目录
.settings/
# Fleet IDE 配置
.fleet/
# Scala Metals 配置
.metals/
# Bloop 编译服务器
.bloop/

# ========== 编译产物 & 缓存文件 ==========
# 编译输出目录 (所有层级)
**/target/
**/build/
**/out/
**/bin/
!**/src/bin/
# Java/Scala 编译生成的类文件
classes/
*.class
# 各类缓存与日志
*.cache
.cache/
*.log
logs/

# ========== Java 特定 ==========
*.jar
*.war
*.ear
*.javap
*.jmap
*.jstack
# Java 快照文件
*.snap

# ========== Scala 特定 ==========
*.scala.html
*.sbt
# Ivy 依赖缓存
.ivy2/
*.ivy
# Scala sbt 项目的编译目录
project/target/
# sbt 锁文件
build.sbt.lock

# ========== Rust 特定 ==========
# Rust 备份文件
*.rs.bk
**/*.rs.bk
# Rust 依赖锁文件 (在多项目仓库中通常建议忽略，除非是顶级二进制项目)
Cargo.lock
# Rust 编译产物
*.rlib
*.dll
*.so
*.dylib
# Rust 编译器信息与缓存
.rustc_info.json
CACHEDIR.TAG

# ========== Gradle 特定 ==========
# Gradle 运行时产生的目录
.gradle/
# Gradle 构建输出目录已经由 **/build/ 涵盖
# 保留 Gradle Wrapper 核心文件
!gradle/wrapper/gradle-wrapper.jar
# 本地 Gradle 配置 (通常包含本地路径，不建议提交)
local.properties
# 允许提交 build.gradle 和 settings.gradle
!build.gradle
!settings.gradle

# ========== Node.js 特定 ==========
# 依赖包目录
**/node_modules/
# npm/Yarn/pnpm 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
# 前端构建输出
dist/
# 测试覆盖率报告
coverage/
# TypeScript 构建信息
*.tsbuildinfo
# 源码映射与类型定义
*.js.map
*.d.ts
# 脚本文件
*.cmd
*.ps1
*.bat
# Lock 文件 (说明：在多项目学习仓库中，忽略 lock 文件可以保持提交整洁；
# 如果是正式生产项目，建议注释掉以下规则以保留 lock 文件)
# Cargo.lock
# yarn.lock
# package-lock.json
# pnpm-lock.yaml
# bun.lock

# ========== Maven 特定 ==========
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ========== Python 特定 ==========
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
*.egg-info/
*.egg

# ========== Go 特定 ==========
*.exe
*.exe~
*.test
*.out
go.work
vendor/

# ========== C/C++ 特定 ==========
*.o
*.a
*.obj
*.elf
*.gch
*.pch
*.dSYM/
*.su
*.idb
*.pdb
*.ilk
*.exp
*.lib

# ========== 其他常用规则 ==========
# 缓存文件夹
.crush/
# 进程与种子
*.pid
*.seed
*.pid.lock
# 敏感环境变量文件
.env
.env.local
.env.*.local
# Git 冲突文件
*.orig
*.rej